[Unit]
Description=TailStreamer Docker Compose stack
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/home/patrik/media-streamer/ops/docker
EnvironmentFile=/home/patrik/media-streamer/.env
ExecStart=/usr/bin/docker compose --profile runner up -d --remove-orphans
ExecStop=/usr/bin/docker compose --profile runner down
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
