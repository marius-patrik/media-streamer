{
  "name": "tailstreamer",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun --filter @tailstreamer/web dev",
    "dev:api": "bun --filter @tailstreamer/api dev",
    "build": "bun --filter '*' build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "bun test",
    "spec:check": "bun scripts/spec-check.ts",
    "check": "bun run spec:check && bun run typecheck && bun run lint && bun test"
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.1.14",
    "typescript": "^5.6.3"
  }
}
